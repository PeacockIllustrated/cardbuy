# ================================================================
# cardbuy — environment variables
# ================================================================
# Copy this file to `.env.local` and fill in real values. `.env.local`
# is gitignored; this `.env.example` is the source of truth for what's
# required.
# ================================================================

# ---- Supabase (Phase 2a) --------------------------------------------
# Project URL and anon key from https://app.supabase.com → Settings → API.
# Both are safe to expose to the browser (NEXT_PUBLIC_* → bundled).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: production site URL, used as the magic-link redirect base.
# Falls back to the request's `origin` header, so only needed if you
# see links pointing at the wrong host.
NEXT_PUBLIC_SITE_URL=

# ---- Later phases ---------------------------------------------------
# Phase 2b:
#   POKEMONTCG_IO_API_KEY=
#   POKEMON_PRICE_TRACKER_API_KEY=
#   OPEN_ER_API_KEY=
# Phase 4:
#   PAYPAL_CLIENT_ID=
#   PAYPAL_CLIENT_SECRET=
#   STRIPE_SECRET_KEY=
#   STRIPE_WEBHOOK_SECRET=
