# ================================================================
# cardbuy — environment variables
# ================================================================
# Copy this file to `.env.local` and fill in real values. `.env.local`
# is gitignored; this `.env.example` is the source of truth for what's
# required.
# ================================================================

# ---- Supabase (Phase 2a) --------------------------------------------
# Project URL and anon key from https://app.supabase.com → Settings → API.
# Both are safe to expose to the browser (NEXT_PUBLIC_* → bundled).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Supabase service role (Phase 2b.2) -----------------------------
# Service-role key (NOT public). Used by the nightly price-sync cron
# and any server-only batch job that needs to bypass RLS.
# Find it in Supabase → Settings → API → service_role secret.
# NEVER expose this to the browser — keep it un-prefixed (no NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=

# ---- Cron auth (Phase 2b.2) -----------------------------------------
# Shared secret for /api/cron/sync-prices. Vercel Cron passes it as
# `Authorization: Bearer <CRON_SECRET>` automatically when the var is
# set in the project environment. Generate with `openssl rand -hex 32`.
CRON_SECRET=

# Optional: production site URL, used as the magic-link redirect base.
# Falls back to the request's `origin` header, so only needed if you
# see links pointing at the wrong host.
NEXT_PUBLIC_SITE_URL=

# ---- Later phases ---------------------------------------------------
# Phase 2b.3 (FX cron, currently free / no key):
#   OPEN_ER_API_KEY=
# Phase 4:
#   PAYPAL_CLIENT_ID=
#   PAYPAL_CLIENT_SECRET=
#   STRIPE_SECRET_KEY=
#   STRIPE_WEBHOOK_SECRET=
